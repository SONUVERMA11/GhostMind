# Google Gemini API Key (Required)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI Whisper API Key (Optional - for audio transcription)
# If not provided, falls back to Google Speech-to-Text
OPENAI_API_KEY=your_openai_api_key_here

# Interview Context (Optional - customize AI persona)
INTERVIEW_ROLE=Software Engineer
INTERVIEW_COMPANY=Tech Company

# Overlay Settings
OVERLAY_OPACITY=0.95
OVERLAY_POSITION=top-right
OVERLAY_WIDTH=480
OVERLAY_HEIGHT=700
